# Hub 服务配置

# HTTP 服务端口
HUB_PORT=9000
HUB_HOST=0.0.0.0

# 运行环境：development / production
HUB_ENV=development

# PostgreSQL
HUB_DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname?sslmode=disable

# Redis
HUB_REDIS_URL=redis://127.0.0.1:6379/0

# Sub2api 源码路径（用于 go.mod replace，本地开发用）
SUB2API_SOURCE_PATH=/opt/sub2api-src/backend

# JWT 配置（必须与 sub2api 一致）
HUB_JWT_SECRET=change-me-to-a-random-64-char-hex-string

# 日志
HUB_LOG_LEVEL=info
HUB_LOG_PATH=/var/log/sub2api-hub

# 锁默认配置
HUB_LOCK_DEFAULT_TTL_SECONDS=300
HUB_LOCK_CLEANUP_INTERVAL_SECONDS=60
HUB_LOCK_MAX_TTL_SECONDS=3600

# CORS
HUB_CORS_ORIGINS=http://localhost:5173
